{
  "name": "ui-audit",
  "version": "2.0.0",
  "description": "DOM property extraction + accessibility tree fingerprints for AI agent UI verification",
  "type": "module",
  "bin": {
    "ui-audit": "./bin/ui-audit.sh"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "capture": "tsx src/cli.ts capture",
